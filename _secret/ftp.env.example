# Deploiement FTP via ./deploy.sh — copie ce fichier en _secret/ftp.env et
# remplis FTP_PASS. Fichier _secret/ftp.env GITIGNORE : ne jamais le committer.
FTP_HOST="xxxx.ftp.infomaniak.com"
FTP_USER="xxxx_user"
FTP_PASS="mot_de_passe_ftp"
# FTP_DIR : sous-dossier cible SOUS la racine du compte FTP. Le compte dedie
# NSY arrive deja sur la racine web servie par le domaine -> LAISSER VIDE.
# Ne mets "web" que si ton compte FTP atterrit un cran au-dessus du docroot.
FTP_DIR=""
