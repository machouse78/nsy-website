# Deny ALL direct HTTP access to anything in this directory.
# Only PHP scripts in the parent directory (e.g. contact.php) can
# `require` files from here via the local filesystem.

# Apache 2.4+
Require all denied

# Apache 2.2 (fallback)
<IfModule !mod_authz_core.c>
  Order Allow,Deny
  Deny from all
</IfModule>
