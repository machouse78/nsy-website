# NSY Website - Configuration Infomaniak
# Optimisé pour hébergement mutualisé Apache

# Index page
DirectoryIndex index.html

# Pages d'erreur personnalisées
ErrorDocument 404 /index.html

# ───── Sécurité : headers HTTP ─────
# (uniquement si mod_headers est chargé, sinon ignoré silencieusement)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ───── Compression GZIP ─────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ───── Cache navigateur : revalidation pour propager les mises à jour ─────
# On ne "vide" pas le cache des visiteurs à distance : on demande à leur
# navigateur de REVALIDER auprès du serveur avant de réutiliser un fichier.
#   • Fichier inchangé  → réponse 304 (rien n'est re-téléchargé, rapide).
#   • Fichier réuploadé → réponse 200 avec la nouvelle version.
# Apache envoie automatiquement Last-Modified + ETag : la revalidation
# se base dessus, donc un simple réupload (date/taille modifiée) suffit.
<IfModule mod_headers.c>
    # HTML / CSS / JS / data : revalidés à CHAQUE visite.
    # → un réupload est visible IMMÉDIATEMENT par les visiteurs.
    <FilesMatch "\.(html|htm|css|js|mjs|json|xml|webmanifest)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # Médias lourds (images, polices, vidéos, modèle 3D) : gardés 1 jour
    # puis revalidés. Ils changent rarement → mis à jour sous 24 h maxi
    # (ou tout de suite avec un rechargement forcé Cmd/Ctrl+Shift+R).
    # C'est le "1 fois par jour" demandé, sans pénaliser les performances.
    <FilesMatch "\.(png|jpe?g|webp|gif|svg|ico|avif|woff2?|ttf|otf|eot|mp4|webm|ogv|glb|gltf)$">
        Header set Cache-Control "max-age=86400, must-revalidate"
    </FilesMatch>
</IfModule>

# ───── Types MIME ─────
<IfModule mod_mime.c>
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType application/javascript .js
</IfModule>

# (Le cache des vidéos est désormais géré dans le bloc « Cache navigateur »
#  ci-dessus : 1 jour + revalidation, comme les autres médias.)

# ───── Protection des fichiers sensibles ─────
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|env|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# ───── Forcer HTTPS + www (hôte canonique : https://www.nsy.fr) ─────
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Un seul 301 vers l'hôte canonique : évite les doublons d'indexation
    # http/https ET www/non-www. Toutes les balises canoniques pointent
    # vers https://www.nsy.fr — cette règle aligne le serveur dessus.
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^www\.nsy\.fr$ [NC]
    RewriteRule ^ https://www.nsy.fr%{REQUEST_URI} [L,R=301]

    # ───── Redirections 301 anciennes URLs → nouvelles ─────
    # Ces 301 préservent le SEO et évitent les 404 depuis les backlinks /
    # Search Console.
    # Les anciennes pages Loisirs/Hobbies pointent vers la page dédiée
    # Conception 3D (conception-3d.html / 3d-design.html).
    RewriteRule ^hobbie\.html$              /conception-3d.html  [L,R=301]
    RewriteRule ^hobbie-en\.html$           /3d-design.html      [L,R=301]
    RewriteRule ^loisirs\.html$             /conception-3d.html  [L,R=301]
    RewriteRule ^hobbies\.html$             /3d-design.html      [L,R=301]
    # Pages légales : traductions de slug FR ↔ EN.
    RewriteRule ^mentions-legales-en\.html$ /legal-notice.html   [L,R=301]
    RewriteRule ^confidentialite-en\.html$  /privacy.html        [L,R=301]

    # ───── Auto-détection langue (Accept-Language) ─────
    # Sur racine ou /index.html : si pas de cookie nsy_lang ET navigateur en anglais,
    # rediriger vers /index-en.html. Le cookie est posé par le switch de drapeau JS,
    # donc dès qu'un utilisateur a choisi une langue, on respecte son choix.
    RewriteCond %{HTTP_COOKIE} !nsy_lang= [NC]
    RewriteCond %{HTTP:Accept-Language} ^en [NC]
    RewriteCond %{REQUEST_URI} ^/(index\.html)?$
    RewriteRule ^ /index-en.html [L,R=302]

    # ───── Anti-hotlink sur médias propriétaires (mp4, glb, gltf) ─────
    # Bloque l'embed direct depuis un autre domaine. Les requêtes "directes"
    # (Referer vide = barre d'adresse) sont autorisées pour ne pas casser
    # les téléchargements légitimes via DevTools / l'utilisateur déterminé,
    # mais ça bloque 99 %% des bots et des sites tiers qui embarqueraient.
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?nsy\.fr/ [NC]
    RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
    RewriteRule \.(mp4|webm|ogv|glb|gltf)$ - [F,L]
</IfModule>
