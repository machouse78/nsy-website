# NSY Website - Configuration Infomaniak
# Optimisé pour hébergement mutualisé Apache

# Index page
DirectoryIndex index.html

# Pages d'erreur personnalisées
ErrorDocument 404 /index.html

# ───── Sécurité : headers HTTP ─────
# (uniquement si mod_headers est chargé, sinon ignoré silencieusement)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ───── Compression GZIP ─────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ───── Cache navigateur ─────
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"

    # Vidéos
    ExpiresByType video/mp4 "access plus 1 month"

    # CSS et JS
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"

    # Fonts
    ExpiresByType font/woff2 "access plus 1 month"
    ExpiresByType font/woff "access plus 1 month"

    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ───── Types MIME ─────
<IfModule mod_mime.c>
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType application/javascript .js
</IfModule>

# ───── Cache vidéos (header explicite, en plus du mod_expires) ─────
<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|webm|ogv)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

# ───── Protection des fichiers sensibles ─────
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|env|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# ───── Forcer HTTPS ─────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ───── Redirections 301 anciennes URLs → nouvelles ─────
    # Ces 301 préservent le SEO et évitent les 404 depuis les backlinks /
    # Search Console.
    # Les pages Loisirs/Hobbies autonomes ont été fusionnées dans une section
    # de la page d'accueil (#creations) — toutes leurs anciennes URLs y pointent.
    RewriteRule ^hobbie\.html$              /#creations          [L,R=301]
    RewriteRule ^hobbie-en\.html$           /index-en.html#creations [L,R=301]
    RewriteRule ^loisirs\.html$             /#creations          [L,R=301]
    RewriteRule ^hobbies\.html$             /index-en.html#creations [L,R=301]
    # Pages légales : traductions de slug FR ↔ EN.
    RewriteRule ^mentions-legales-en\.html$ /legal-notice.html   [L,R=301]
    RewriteRule ^confidentialite-en\.html$  /privacy.html        [L,R=301]

    # ───── Auto-détection langue (Accept-Language) ─────
    # Sur racine ou /index.html : si pas de cookie nsy_lang ET navigateur en anglais,
    # rediriger vers /index-en.html. Le cookie est posé par le switch de drapeau JS,
    # donc dès qu'un utilisateur a choisi une langue, on respecte son choix.
    RewriteCond %{HTTP_COOKIE} !nsy_lang= [NC]
    RewriteCond %{HTTP:Accept-Language} ^en [NC]
    RewriteCond %{REQUEST_URI} ^/(index\.html)?$
    RewriteRule ^ /index-en.html [L,R=302]

    # ───── Anti-hotlink sur médias propriétaires (mp4, glb, gltf) ─────
    # Bloque l'embed direct depuis un autre domaine. Les requêtes "directes"
    # (Referer vide = barre d'adresse) sont autorisées pour ne pas casser
    # les téléchargements légitimes via DevTools / l'utilisateur déterminé,
    # mais ça bloque 99 %% des bots et des sites tiers qui embarqueraient.
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?nsy\.fr/ [NC]
    RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
    RewriteRule \.(mp4|webm|ogv|glb|gltf)$ - [F,L]
</IfModule>
